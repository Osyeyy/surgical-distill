{
  "comment": "Arm B — KL-only control. Same hyperparameters as v1.1 but act_weight=0 so the activation signal contributes nothing. Tells us what plain KL distillation alone achieves at this compute budget.",

  "use_qlora": true,
  "freeze_projection": true,

  "strategy": "all",
  "top_k": 4,
  "softmax_temp": 1.5,
  "cosine_weight": 1.0,
  "mse_weight": 0.0,

  "last_n_skip": 4,
  "act_weight": 0.0,
  "kl_weight": 0.5,
  "kl_temperature": 2.0,

  "lr": 1e-5,
  "grad_clip": 1.0,
  "max_length": 384,
  "steps": 2000,
  "log_every": 20,
  "save_every": 500,

  "dataset_name": "Malum0x/openhermes2.5-Perplexity_filtered_top30",
  "dataset_split": "train",

  "curriculum": null
}
